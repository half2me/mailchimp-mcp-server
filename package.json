{
  "name": "mailchimp-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Mailchimp Marketing API integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mailchimp-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "bundle": "esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=bundle/index.cjs",
    "clean": "rm -rf dist",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.81.1"
  }
}
